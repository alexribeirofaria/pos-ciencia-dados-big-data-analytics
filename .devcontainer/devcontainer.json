{
  "name": "R + Python DevContainer",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "rstudio",
  "containerUser": "rstudio",
  "updateRemoteUserUID": true,
  "workspaceFolder": "/home/rstudio/workspace", 
  "mounts": [
    "source=${localWorkspaceFolder},target=/home/rstudio/workspace,type=bind"
  ],
  "forwardPorts": [
    8787,
    8888
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "REditorSupport.r",
        "reditorsupport.r-lsp"
      ]
    }
  }
}